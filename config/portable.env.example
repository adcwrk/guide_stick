# GUIDE runtime configuration.
# Copy to config/portable.env for local overrides.

ENABLE_REMOTE_ACCESS=true
ENABLE_REMOTE_OLLAMA=false
ENABLE_AUTH=true
ANYTHINGLLM_PORT=3001
OPENWEBUI_PORT=8080
OLLAMA_PORT=11434
BIND_ADDRESS=0.0.0.0
LAN_ONLY=true

# GUI startup controls.
ENABLE_ANYTHINGLLM=true
ENABLE_OPENWEBUI=true
ANYTHINGLLM_RUNTIME=auto
ANYTHINGLLM_IMAGE=mintplexlabs/anythingllm:latest
ANYTHINGLLM_APPIMAGE_URL=https://cdn.anythingllm.com/latest/AnythingLLMDesktop.AppImage

# Optional model pulls during setup.
PULL_DEFAULT_MODELS=true
PULL_OPTIONAL_MODELS=false

# Optional command overrides. Leave blank to auto-detect.
OLLAMA_BIN=
OPENWEBUI_BIN=
ANYTHINGLLM_BIN=

# Lightweight GUIDE WebUI authentication.
# When ENABLE_AUTH=true, scripts/guide-webui.py enforces HTTP Basic auth.
# Default user is guide. If neither GUIDE_WEBUI_PASSWORD nor
# GUIDE_WEBUI_PASSWORD_FILE is set, the WebUI generates a password at:
# config/guide-webui.password
GUIDE_WEBUI_USER=guide
GUIDE_WEBUI_PASSWORD_FILE=
GUIDE_WEBUI_PASSWORD=

# Do not put passwords in portable.env unless the USB is physically protected.
# Prefer GUIDE_WEBUI_PASSWORD_FILE or the GUI's first-run admin setup where available.
